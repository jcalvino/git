# ─────────────────────────────────────────────
#  BTC/ETH Trader — Environment Variables
#  Copy to .env and fill in your values:
#
#    copy .env.example .env
#
#  NUNCA commite o .env no git — contém suas API keys.
# ─────────────────────────────────────────────

# ── BingX API (USDT-M Perpetual Futures) ──────
# Gere em: BingX → Profile → API Management → Criar API Key
# Permissões necessárias: Futures Read + Futures Trade
# NUNCA marque "Withdraw" — não é necessário e representa risco.
BINGX_API_KEY=your_api_key_here
BINGX_SECRET_KEY=your_secret_key_here

# ── Modo de Trading ────────────────────────────
# true  = paper trade (simula sem enviar ordens reais)
# false = live trading (cuidado: envia ordens reais à BingX)
PAPER_TRADE=true

# ── Capital & Risco ────────────────────────────
# Capital total em USDT alocado ao bot
CAPITAL_USDT=315

# Risco máximo por trade como decimal (0.01 = 1% do capital)
MAX_RISK_PCT=0.01

# Score/confiança mínimo (0-100) para gerar um alerta de sinal
MIN_SCORE=65

# ── Agenda do Bot ─────────────────────────────
# Expressão cron para intervalo de scan (padrão: a cada 4 horas)
SCAN_CRON=0 */4 * * *

# ── Servidor ──────────────────────────────────
API_PORT=3001
DASHBOARD_PORT=3000

# ── Coin-M Futures (BTC-USD) ──────────────────
# ⚠ RISCO: Coin-M usa BTC como colateral. P&L em BTC.
# Double exposure em LONG (se BTC subir, trade E colateral sobem).
# Só ative quando tiver BTC na conta e entender os riscos.
COINM_ENABLED=false
# Capital alocado para Coin-M em BTC (independente do capital USDT-M)
COINM_CAPITAL_BTC=0.001

# ── CoinGlass API ─────────────────────────────
# Endpoints públicos gratuitos não exigem chave.
# Se você tiver uma chave paga, coloque aqui para limites maiores.
# COINGLASS_API_KEY=your_key_here

# ── Caminhos ──────────────────────────────────
# rules.json fica na raiz do projeto (claudecode-trade/)
TV_RULES_PATH=./rules.json

# Banco de dados SQLite
DB_PATH=./data/trades.db

# ─────────────────────────────────────────────
#  ClaudeCode-Trade — Variáveis para PRODUÇÃO AWS
#  Copie este arquivo para .env.production no seu PC local.
#  NUNCA commitar .env.production no git.
#  O deploy.sh envia este arquivo via scp com chmod 600 para a EC2.
# ─────────────────────────────────────────────

# ── BingX ──────────────────────────────────────
# Permissões: Futures Read + Futures Trade. NUNCA Withdraw.
# IP whitelist: coloque o Elastic IP da EC2.
BINGX_API_KEY=your_api_key_here
BINGX_SECRET_KEY=your_secret_key_here
BINGX_BASE_URL=https://open-api.bingx.com

# ── Modo ───────────────────────────────────────
# MANTENHA true por no mínimo 2 semanas em produção antes de mudar.
PAPER_TRADE=true

# ── Capital e risco ────────────────────────────
CAPITAL_USDT=1100
MAX_RISK_PCT=0.01
MIN_SCORE=65

# ── Cron do scanner ────────────────────────────
SCAN_CRON=0 */4 * * *

# ── API & host ─────────────────────────────────
# Em produção, bind em loopback — Tailscale cuida do acesso externo.
API_HOST=127.0.0.1
API_PORT=3001
DASHBOARD_PORT=3000

# ── Paths (absolutos na EC2) ───────────────────
TV_RULES_PATH=/opt/claudecode-trade/rules.json
DB_PATH=/opt/claudecode-trade/data/trades.db

# ── Coin-M (desabilitado por padrão) ───────────
COINM_ENABLED=false
COINM_CAPITAL_BTC=0.001

# ── CoinGlass (opcional) ───────────────────────
# COINGLASS_API_KEY=

# ── Telegram ───────────────────────────────────
# Token do BotFather (@BotFather → /newbot)
TELEGRAM_BOT_TOKEN=0000000000:AAAA-REPLACE_ME

# chat_id seu (pegue em https://api.telegram.org/bot<TOKEN>/getUpdates)
# Múltiplos: "123,456"
TELEGRAM_ALLOWED_CHAT_IDS=000000000

# PIN numérico de 6 dígitos — diferente de senhas usadas em outros lugares.
TELEGRAM_PIN=000000

# Parâmetros de sessão
TELEGRAM_SESSION_HOURS=4
TELEGRAM_RATE_LIMIT_PER_HOUR=10

# Opcional: chat separado para alertas de segurança (tentativas de PIN, etc)
# TELEGRAM_ALERT_CHAT_ID=

# ── Claude Code ────────────────────────────────
# Criar em https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Parâmetros de execução
CLAUDE_MAX_TURNS=20
CLAUDE_WORKDIR=/opt/claudecode-trade
# CLAUDE_MODEL=claude-sonnet-4-6

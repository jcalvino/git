{
  "name": "real-estate-pt",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r build && pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:watch": "pnpm --filter @real-estate/finance test:watch",
    "dev": "pnpm -r --parallel dev",
    "dev:app": "pnpm --parallel --filter @real-estate/api --filter @real-estate/web dev",
    "clean": "pnpm -r exec rimraf dist .tsbuildinfo"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}

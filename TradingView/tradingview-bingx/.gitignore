# ─────────────────────────────────────────────
#  Git Ignore — Protege dados sensíveis
# ─────────────────────────────────────────────

# Env / secrets
.env
.env.*
!.env.example
*.pem
*.key

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs
dist/
build/
.next/
.cache/
dashboard/dist/
dashboard/build/

# Data / banco local
data/
*.db
*.db-journal
*.db-wal
*.db-shm

# Logs
logs/
*.log

# Debug / scratch artifacts na raiz
/eth.json
/btc.json
/*.debug.json
/scratch.*
/tmp.*

# Sistema
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Coverage / test output
coverage/
.nyc_output/

{
  "name": "tradingview-bingx",
  "version": "1.0.0",
  "description": "Semi-automated BTC/ETH trading system - BingX USDC-M Perpetual Futures",
  "type": "module",
  "main": "src/bot/scanner.js",
  "scripts": {
    "start": "node scripts/start.js",
    "stop": "node scripts/stop.js",
    "restart": "node scripts/restart.js",
    "reset": "node scripts/reset-stack.js",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "docker:reset": "docker compose down -v && docker compose up -d --build",
    "update-rules": "node scripts/update-rules.js",
    "scan": "node src/bot/scanner.js --once",
    "bot": "node src/bot/scanner.js",
    "monitor": "node src/bot/monitor.js",
    "api": "node src/api/server.js",
    "dashboard": "npm run dev --prefix dashboard",
    "test:config": "node src/config/index.js",
    "test:technical": "node src/analysis/technical.js",
    "test:signals": "node src/strategy/signals.js",
    "test:bingx": "node src/exchanges/bingx.js",
    "test:withdraw": "node src/exchanges/withdraw.js",
    "validate-symbols": "node scripts/validate-symbols.js"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^4.21.2",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.66.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
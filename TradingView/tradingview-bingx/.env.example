# ─────────────────────────────────────────────
#  BTC/ETH Trader — Environment Variables
#  Copy to .env and fill in your values:
#
#    copy .env.example .env
#
#  NUNCA commite o .env no git — contém suas API keys.
# ─────────────────────────────────────────────

# ── BingX API — TRADE key (USDC-M Perpetual Futures) ──────
# Gere em: BingX → Profile → API Management → Criar API Key
# Permissões desta key (somente estas):
#   - Futures Read   (obrigatório)
#   - Futures Trade  (obrigatório para envio de ordens)
#
# NÃO habilite Withdraw nem Internal Transfer nesta key.
# Se esta key vazar, o atacante não consegue sacar fundos.
BINGX_API_KEY=your_trade_api_key_here
BINGX_SECRET_KEY=your_trade_secret_key_here

# ── Modo de Trading ────────────────────────────
# true  = paper trade (simula sem enviar ordens reais)
# false = live trading (cuidado: envia ordens reais à BingX)
PAPER_TRADE=true

# ── Capital & Risco ────────────────────────────
# Capital total em USDC alocado ao bot
CAPITAL_USDT=315

# Risco máximo por trade como decimal (0.01 = 1% do capital)
MAX_RISK_PCT=0.01

# Score/confiança mínimo (0-100) para gerar um alerta de sinal
MIN_SCORE=65

# ── Agenda do Bot ─────────────────────────────
# Expressão cron para intervalo de scan (padrão: a cada 4 horas)
SCAN_CRON=0 */4 * * *

# ── Servidor ──────────────────────────────────
API_PORT=3001
DASHBOARD_PORT=3000

# ── Telegram — Alertas (Fase 1, read-only) ────
# Notificações do bot no celular. Só ENVIA mensagens; ainda não recebe
# comandos (Fase 2 adiciona /panic, /status, /approve, …).
#
# Setup rápido (ver SETUP_TELEGRAM.md):
#   1. Fale com @BotFather no Telegram → /newbot → copie o token
#   2. Fale com @userinfobot → copie seu chat_id numérico
#   3. Cole abaixo e mude TELEGRAM_ENABLED=true
#
# TELEGRAM_ALLOWED_CHAT_IDS aceita lista separada por vírgula
# (ex: 12345,67890) — cada chat_id listado recebe todas as mensagens.
# Na Fase 2 essa mesma lista vira whitelist de quem pode mandar comandos.
#
# Se TELEGRAM_ENABLED=false ou qualquer var vazia: notifier vira no-op
# silenciosamente (nada é enviado). Zero impacto na execução dos trades.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# ── CoinGlass API ─────────────────────────────
# Endpoints públicos gratuitos não exigem chave.
# Se você tiver uma chave paga, coloque aqui para limites maiores.
# COINGLASS_API_KEY=your_key_here

# ── Caminhos ──────────────────────────────────
# rules.json fica na raiz do projeto (tradingview-bingx/)
TV_RULES_PATH=./rules.json

# Banco de dados SQLite
DB_PATH=./data/trades.db
